### CORS资源共享设置
## 如果你需要配置, 请取消下面的注释并设置具体的域名
# CORS_ALLOW_ORIGIN = "*"

### Heartide 服务鉴权
## 生产 / 局域网部署建议保持开启；本地临时调试可设为 false
HEARTIDE_AUTH_ENABLED = true
HEARTIDE_APP_ID = "heartide"
## 请部署时替换为足够长的随机字符串，不要提交真实密钥
HEARTIDE_APP_SECRET = "replace-with-a-long-random-secret"
## 请求时间戳允许误差，单位秒
HEARTIDE_AUTH_MAX_SKEW_SECONDS = 300
## nonce 防重放缓存时间，单位秒
HEARTIDE_AUTH_NONCE_TTL_SECONDS = 300
## 免签路径。NCM 业务接口不要放进这里
HEARTIDE_AUTH_PUBLIC_PATHS = "/health"

### Heartide 管理 / 文档访问登录
## 保护首页、/docs、/static 和 public 下的 HTML / 静态资料；不替代 App 接口签名
HEARTIDE_ADMIN_AUTH_ENABLED = true
HEARTIDE_ADMIN_USERNAME = "admin"
## 推荐只配置 SHA256 值：printf 'your-password' | shasum -a 256
HEARTIDE_ADMIN_PASSWORD_SHA256 = "replace-with-password-sha256"
## 本地临时调试才使用明文密码；生产环境不要配置明文
# HEARTIDE_ADMIN_PASSWORD = "replace-with-dev-password"
HEARTIDE_ADMIN_SESSION_SECRET = "replace-with-a-long-random-session-secret"
HEARTIDE_ADMIN_SESSION_TTL_SECONDS = 43200
HEARTIDE_ADMIN_LOGIN_MAX_ATTEMPTS = 8
HEARTIDE_ADMIN_LOGIN_WINDOW_SECONDS = 300

### 代理设置
## 启用反向代理
ENABLE_PROXY = false
## 代理配置
PROXY_URL = "https://your-proxy-url.com/?proxy="

### 随机IP设置
## 启用随机中国IP（默认关闭）；启用后，所有请求默认使用随机中国IP，除非请求参数randomCNIP显式关闭
ENABLE_RANDOM_CN_IP = false

### UnblockNeteaseMusic 设置项
## 启用全局解灰, 无论是否调用参数都会使用解灰(不推荐开启)
ENABLE_GENERAL_UNBLOCK = false
## 歌曲启用无损音质
ENABLE_FLAC = true
## 启用无损音质时，是否选择音质最高的
SELECT_MAX_BR = false
## 严格按照配置音源设置顺序进行匹配
FOLLOW_SOURCE_ORDER = true
## Cookie设置项; 推荐在Vercel等平台进行环境变量的设置或者设置github secret
# 网易云 cookie
# 格式：MUSIC_U=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NETEASE_COOKIE = ""
